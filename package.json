{
    "name": "appstore-connect-mcp",
    "version": "1.0.1",
    "description": "MCP server for interacting with App Store Connect",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "appstore-connect-mcp": "./dist/index.js"
    },
    "scripts": {
        "build": "bun build src/index.ts --outdir dist --target node --format esm --banner '#!/usr/bin/env node'",
        "prepublishOnly": "bun run build",
        "start": "node dist/index.js",
        "dev": "bun src/index.ts",
        "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
        "mcp:add": "claude mcp add appstore-connect-mcp -- bun $PWD/src/index.ts",
        "mcp:remove": "claude mcp remove appstore-connect-mcp",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "generate:api": "openapi-ts --input openapi.oas.json --output src/api --client axios"
    },
    "keywords": [
        "mcp",
        "appstore",
        "app-store-connect",
        "ios",
        "apple",
        "deployment"
    ],
    "author": "Khoa Pham",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/khoa/appstore-connect-mcp.git"
    },
    "homepage": "https://github.com/khoa/appstore-connect-mcp",
    "bugs": {
        "url": "https://github.com/khoa/appstore-connect-mcp/issues"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.25.1",
        "axios": "^1.6.5",
        "jsonwebtoken": "^9.0.2",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.15.0",
        "@hey-api/openapi-ts": "^0.46.3",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^22.9.1",
        "eslint": "^9.15.0",
        "prettier": "^3.3.3",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.15.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}